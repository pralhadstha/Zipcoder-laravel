{
    "name": "pralhadstha/zipcoder-laravel",
    "description": "Laravel package to resolve postal codes and zip codes to addresses. Supports multiple geocoding providers with automatic failover, built-in caching, Facade support, and publishable config.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/pralhadstha/zipcoder-laravel",
    "keywords": [
        "laravel",
        "postal-code",
        "zip-code",
        "zipcode",
        "address",
        "geocoding",
        "lookup",
        "zipcoder",
        "cache",
        "chain",
        "failover"
    ],
    "authors": [
        {
            "name": "Pralhad Kumar Shrestha",
            "homepage": "https://github.com/pralhadstha"
        }
    ],
    "require": {
        "php": "^8.2",
        "pralhadstha/zipcoder-php": "^1.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Pralhad\\Zipcoder\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pralhad\\Zipcoder\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pralhad\\Zipcoder\\Laravel\\ZipcoderServiceProvider"
            ],
            "aliases": {
                "Zipcoder": "Pralhad\\Zipcoder\\Laravel\\Facades\\Zipcoder"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint",
        "check-style": "vendor/bin/pint --test"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
